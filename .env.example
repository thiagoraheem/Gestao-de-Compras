# Runtime / Ambiente
# NODE_ENV: define o ambiente de execução do Node/Express.
# Valores esperados: development | production | test
# Padrão (quando não definido): development (no dev) / production (no start)
NODE_ENV=development

# PORT: porta onde o servidor HTTP (API + frontend) escuta.
# Formato: inteiro
# Padrão: 3000
PORT=3000

# APP_MODE: usado no build:dev para forçar carregamento de .env.development.
# Valores esperados: development (ou vazio/omitido)
# Padrão: (omitido)
APP_MODE=

# REPLIT_DOMAINS / REPL_ID: usados apenas em ambientes Replit (auto-injetados lá).
# Padrão: (omitido)
REPLIT_DOMAINS=
REPL_ID=

# Database Configuration
# DATABASE_URL_DEV: URL do Postgres para desenvolvimento (usada quando NODE_ENV != production).
# Formato: postgres://USER:PASSWORD@HOST:PORT/DBNAME (ou postgresql://...)
DATABASE_URL_DEV=your_development_postgresql_url_here

# DATABASE_URL: URL do Postgres para produção (usada quando NODE_ENV=production).
# Formato: postgres://USER:PASSWORD@HOST:PORT/DBNAME (ou postgresql://...)
DATABASE_URL=your_postgresql_url_here

# Session Security (Obrigatório)
# SESSION_SECRET: segredo para assinar a sessão (express-session).
# Requisito: mínimo 32 caracteres.
SESSION_SECRET=your_super_secure_session_secret_here_minimum_32_characters

# Cookie / Sessão (Opcional)
# COOKIE_SECURE: força cookie com flag Secure.
# Valores esperados: true | false
# Padrão: auto (true se BASE_URL começar com https://, senão false)
COOKIE_SECURE=

# COOKIE_SAMESITE: política SameSite do cookie de sessão.
# Valores esperados: lax | strict | none
# Padrão: lax
COOKIE_SAMESITE=lax

# Application URLs
# BASE_URL: URL base da aplicação (usada para links em e-mails e para inferir HTTPS).
# Em produção, use seu domínio (ex: https://seu-dominio.com).
# Padrão: http://localhost:5000 (ou REPLIT_DOMAINS quando disponível)
BASE_URL=http://localhost:5000

# FRONTEND_URL: override explícito da URL do frontend (usado para geração de PDFs/capturas).
# Padrão: (quando omitido) usa BASE_URL ou REPLIT_DOMAINS.
FRONTEND_URL=

# External API / Integração Locador
# BASE_API_URL: URL base da API do Locador (ou ERP) usada na integração.
# Formato: URL completa terminando (ou não) com /api
# Observação: no build do frontend, o Vite mapeia BASE_API_URL -> import.meta.env.VITE_BASE_API_URL (não configurar VITE_* manualmente).
# Padrão: http://localhost:5001/api
BASE_API_URL=http://localhost:5225/api

# API_VERSION: versão lógica da API (usada por utilitários da integração Locador).
# Formato: string (ex: v1)
# Padrão: v1
API_VERSION=v1

# API_TIMEOUT_MS: timeout padrão (ms) para chamadas HTTP na integração (config antiga do módulo integracao_locador).
# Formato: inteiro (ms)
# Padrão: 10000
API_TIMEOUT_MS=10000

# LOCADOR_API_TOKEN: token estático opcional (quando a API exigir token fora do fluxo de login).
# Padrão: (omitido)
LOCADOR_API_TOKEN=

# Runtime-config secrets encryption (Obrigatório quando existir setting secreto salvo no banco)
# CONFIG_ENCRYPTION_KEY: chave para criptografar/decriptografar settings marcados como segredo (AES-256-GCM).
# Formato: 32 bytes codificados em base64 (recomendado) ou hex.
CONFIG_ENCRYPTION_KEY=your_32_bytes_key_base64_or_hex_here

# Credenciais fallback (Opcional; usado apenas se o banco ainda não tiver locador.credentials)
# LOCADOR_TECH_LOGIN / LOCADOR_TECH_PASSWORD: credenciais de login na API do Locador.
# Padrão: admin / admin
LOCADOR_TECH_LOGIN=admin
LOCADOR_TECH_PASSWORD=admin

# Ajustes da integração (Opcional)
# CONFIG_CACHE_TTL_MS: TTL do cache (ms) de configs carregadas do banco.
# Formato: inteiro (ms)
# Padrão: 60000
CONFIG_CACHE_TTL_MS=60000

# LOCADOR_HTTP_TIMEOUT_MS: timeout (ms) para chamadas HTTP ao Locador (client autenticado).
# Formato: inteiro (ms)
# Padrão: 25000
LOCADOR_HTTP_TIMEOUT_MS=25000

# LOCADOR_TOKEN_PREEMPT_MS: janela (ms) para renovar token antes do vencimento.
# Formato: inteiro (ms)
# Padrão: 120000
LOCADOR_TOKEN_PREEMPT_MS=120000

# ERP Integration
# ERP_INTEGRATION_ENABLED: habilita integração real com ERP; quando false, pode usar dados mock/fallback.
# Valores esperados: true | false
# Padrão: false
ERP_INTEGRATION_ENABLED=false

# ERP_SUPPLIER_PAGE_SIZE: tamanho de página usado ao sincronizar fornecedores do ERP.
# Formato: inteiro
# Padrão: 200
ERP_SUPPLIER_PAGE_SIZE=200

# ERP_USE_MOCK_FALLBACK: controla fallback para dados mock quando a integração falhar.
# Valores esperados: true | false
# Padrão: true (só desativa se definido como "false")
ERP_USE_MOCK_FALLBACK=true

# Email Configuration (SMTP)
# SMTP_HOST/SMTP_PORT/SMTP_USER/SMTP_PASS: credenciais do servidor SMTP.
# Observação: o envio pode ser desabilitado por segurança via ENABLE_EMAIL_SENDING.
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_USER=your-email@domain.com
SMTP_PASS=your-email-password

# FROM_EMAIL: remetente padrão (From) dos e-mails.
# Formato: email
FROM_EMAIL=sistema@your-company.com

# ENABLE_EMAIL_SENDING: liga/desliga o envio real de e-mails.
# Valores esperados: true | false
# Padrão: false
ENABLE_EMAIL_SENDING=false

# APP_ENV / APP_VERSION: metadados usados em templates/logs de e-mail.
# Padrão: APP_ENV usa NODE_ENV; APP_VERSION usa "1.0.0"
APP_ENV=
APP_VERSION=

# WebSocket (Tempo real)
# WEBSOCKET_URL: URL completa do websocket usada pelo frontend quando há proxy/portas diferentes.
# Formato: ws://HOST:PORT/ws ou wss://HOST/ws
# Observação: no build do frontend, o Vite mapeia WEBSOCKET_URL -> import.meta.env.VITE_WEBSOCKET_URL.
# Padrão: (omitido) frontend usa ws(s)://{window.location.host}/ws
WEBSOCKET_URL=ws://localhost:5201/ws

# Push Notifications (Web Push) (Opcional)
# Para habilitar push, configure as chaves VAPID (public/private) e um subject.
# VAPID_SUBJECT: e-mail ou URL (ex: mailto:dev@empresa.com)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# Logging Configuration
# LOG_LEVEL: nível mínimo de log.
# Valores esperados: error | warn | info | debug
# Padrão: production=error; development=info
LOG_LEVEL=info

# ENABLE_REQUEST_LOGS: liga/desliga logs de requisição HTTP.
# Valores esperados: true | false
# Padrão: true (desliga apenas se definido como "false")
ENABLE_REQUEST_LOGS=true

# LOG_VERBOSE: modo verboso (inclui corpos/mais detalhes em alguns logs/rotas).
# Valores esperados: true | false
# Padrão: false
LOG_VERBOSE=false

# Reports (Opcional)
# REPORT_QUERY_TIMEOUT_MS: timeout (ms) para query do relatório de solicitações de compra.
# Formato: inteiro (ms)
# Padrão: 20000
REPORT_QUERY_TIMEOUT_MS=20000

# File Storage (S3 compatível) (Opcional)
# Quando habilitado, uploads/anexos podem ser armazenados em S3. Caso contrário, usa fallback local.
AWS_S3_ENABLED=false

# AWS_S3_BUCKET: bucket onde os arquivos serão gravados (obrigatório quando AWS_S3_ENABLED=true).
AWS_S3_BUCKET=

# AWS_REGION: região AWS.
# Padrão: us-east-1
AWS_REGION=us-east-1

# AWS_S3_ENDPOINT: endpoint custom (para MinIO/compatíveis). Ex: http://localhost:9000
# Padrão: (omitido)
AWS_S3_ENDPOINT=

# AWS_S3_FORCE_PATH_STYLE: força path-style (necessário em alguns S3 compatíveis).
# Valores esperados: true | false
# Padrão: false
AWS_S3_FORCE_PATH_STYLE=false

# AWS_S3_SIGNED_URL_EXPIRES_IN: expiração (segundos) de URLs assinadas.
# Intervalo permitido: 60 .. 604800 (7 dias)
# Padrão: 3600
AWS_S3_SIGNED_URL_EXPIRES_IN=3600

# AWS_S3_LOCAL_FALLBACK: permite fallback para storage local quando S3 falhar/não estiver configurado.
# Valores esperados: true | false
# Padrão: true (só desativa se definido como "false")
AWS_S3_LOCAL_FALLBACK=true

# Credenciais AWS (Opcional; necessárias se não usar IAM/roles no ambiente)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# PDF / Renderização (Opcional)
# Caminhos para binários de browser/renderer usados por geração de PDF/capturas.
MSEDGE_PATH=C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe
CHROMIUM_PATH=
CHROME_PATH=
GOOGLE_CHROME_BIN=
GOOGLE_CHROME_SHIM=
WKHTMLTOPDF_PATH=

# Scripts de manutenção (Opcional)
# Variáveis usadas por scripts em /scripts para migração/regularização via API.
API_BASE=http://localhost:5201
ADMIN_EMAIL=admin
ADMIN_PASSWORD=admin123
